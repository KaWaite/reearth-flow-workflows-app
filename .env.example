# Copy this to .env.local for local development (never commit .env.local)
#
# Shared API key (GitHub repository secret: FLOW_API_KEY)
VITE_FLOW_API_KEY=your_api_key_here

# Per-workflow trigger URLs (GitHub repository variables: FLOW_URL_<NAME>)
VITE_FLOW_URL_CSV_QUALITY=https://api.flow.reearth.io/api/v1/projects/YOUR_PROJECT/deployments/YOUR_DEPLOYMENT/trigger
VITE_FLOW_URL_GEOJSON=https://api.flow.reearth.io/api/v1/projects/YOUR_PROJECT/deployments/YOUR_DEPLOYMENT/trigger
VITE_FLOW_URL_CSV_MERGE=https://api.flow.reearth.io/api/v1/projects/YOUR_PROJECT/deployments/YOUR_DEPLOYMENT/trigger
VITE_FLOW_URL_COL_SELECT=https://api.flow.reearth.io/api/v1/projects/YOUR_PROJECT/deployments/YOUR_DEPLOYMENT/trigger
VITE_FLOW_URL_CSV_SPLIT=https://api.flow.reearth.io/api/v1/projects/YOUR_PROJECT/deployments/YOUR_DEPLOYMENT/trigger
VITE_FLOW_URL_CSV_JSON=https://api.flow.reearth.io/api/v1/projects/YOUR_PROJECT/deployments/YOUR_DEPLOYMENT/trigger
VITE_FLOW_URL_SPATIAL_FILTER=https://api.flow.reearth.io/api/v1/projects/YOUR_PROJECT/deployments/YOUR_DEPLOYMENT/trigger
