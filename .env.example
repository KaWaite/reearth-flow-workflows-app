# Copy this to .env.local for local development (never commit .env.local)
#
# Shared API key (GitHub repository secret: FLOW_API_KEY)
VITE_FLOW_API_KEY=your_api_key_here

# Per-workflow trigger URLs (GitHub repository variables: FLOW_TRIGGER_URL_1 through _7)
VITE_FLOW_TRIGGER_URL_1=https://your-flow-instance.example.com/api/triggers/WORKFLOW_1_ID
VITE_FLOW_TRIGGER_URL_2=https://your-flow-instance.example.com/api/triggers/WORKFLOW_2_ID
VITE_FLOW_TRIGGER_URL_3=https://your-flow-instance.example.com/api/triggers/WORKFLOW_3_ID
VITE_FLOW_TRIGGER_URL_4=https://your-flow-instance.example.com/api/triggers/WORKFLOW_4_ID
VITE_FLOW_TRIGGER_URL_5=https://your-flow-instance.example.com/api/triggers/WORKFLOW_5_ID
VITE_FLOW_TRIGGER_URL_6=https://your-flow-instance.example.com/api/triggers/WORKFLOW_6_ID
VITE_FLOW_TRIGGER_URL_7=https://your-flow-instance.example.com/api/triggers/WORKFLOW_7_ID
